# Strategy: value (edge betting) | arbitrage
SPORTS_STRATEGY=value
# Gamma tag_id for sports (GET https://gamma-api.polymarket.com/sports to list). Leave empty to scan all active events.
SPORTS_TAG_ID=34
# Poll interval (ms)
SPORTS_POLL_INTERVAL_MS=60000
SPORTS_EVENTS_LIMIT=50

# Value strategy: min edge to place (e.g. 0.02 = 2%)
SPORTS_VALUE_MIN_EDGE=0.02
# Value: fair probability 0–1 (optional; default 0.5)
# SPORTS_VALUE_FAIR_PROB=0.5
# Max USDC per order (0 = use SPORTS_STAKE_USD only)
SPORTS_MAX_ORDER_USD=0
SPORTS_STAKE_USD=10

# Arbitrage: min profit (e.g. 0.01 = 1%)
SPORTS_ARB_MIN_PROFIT=0.01

SPORTS_DRY_RUN=true

POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_FUNDER_ADDRESS=0x...
# POLYMARKET_AUTO_DERIVE_API_KEY=true
